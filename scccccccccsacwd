-- 1. Infinite Jump Logic
local infJump = false
createButton("Inf Jump: OFF", Color3.fromRGB(200, 0, 0), function(self)
    infJump = not infJump
    script.Parent.Text = "Inf Jump: " .. (infJump and "ON" or "OFF")
end)

