-- [[ LOGIC LOOPS ]] --

RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    
    -- Movement Mods
    char.Humanoid.WalkSpeed = states.speed
    char.Humanoid.JumpPower = states.jump
    
    -- Noclip Logic
    if states.noclip then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- Fullbright
    if states.fullbright then
        game.Lighting.Brightness = 2
        game.Lighting.ClockTime = 14
        game.Lighting.OutdoorAmbient = Color3.new(1,1,1)
    end

    -- Combat Logic (Aimbot/Autoshoot)
    if states.aimbot or states.autoshoot then
        local target = nil
        local dist = 500
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("Head") then
                local pos, vis = camera:WorldToViewportPoint(v.Character.Head.Position)
                if vis then
                    local m = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if m < dist then target = v; dist = m end
                end
            end
        end
        if target then
            if states.aimbot then camera.CFrame = CFrame.new(camera.CFrame.Position, target.Character.Head.Position) end
            if states.autoshoot then mouse1press(); task.wait(); mouse1release() end
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
