    if infJump then
        player.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- 2. Speed & Jump Boost
createButton("Boost Stats", Color3.fromRGB(0, 150, 200), function()
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    hum.WalkSpeed = 100
    hum.JumpPower = 150
end)

-- 3. Fly (Simple Hover/Speed)
local flying = false
createButton("Toggle Fly", Color3.fromRGB(150, 0, 200), function()
    flying = not flying
    local bv = Instance.new("BodyVelocity")
    if flying then
        bv.Velocity = Vector3.new(0,0,0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = player.Character.HumanoidRootPart
        while flying do
            bv.Velocity = player.Character.Humanoid.MoveDirection * 50
            wait()
        end
    else
        player.Character.HumanoidRootPart:FindFirstChild("BodyVelocity"):Destroy()
    end
end)

-- 4. Anti-Ragdoll
createButton("Anti-Ragdoll", Color3.fromRGB(0, 200, 100), function()
    player.Character.Humanoid.StateChanged:Connect(function(_, state)
        if state == Enum.HumanoidStateType.Ragdoll then
            player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)
end)

-- 5. Rejoin & Server Hop
createButton("Rejoin", Color3.fromRGB(100, 100, 100), function()
    teleportService:Teleport(game.PlaceId, player)
end)

createButton("Server Hop", Color3.fromRGB(100, 100, 100), function()
    local servers = httpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
    for _, s in pairs(servers.data) do
        if s.playing < s.maxPlayers and s.id ~= game.JobId then
            teleportService:TeleportToPlaceInstance(game.PlaceId, s.id)
        end
    end
end)

