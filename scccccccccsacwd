-- Example for WalkSpeed Toggle:
local function toggleSpeed()
    walkSpeedActive = not walkSpeedActive
    humanoid.WalkSpeed = walkSpeedActive and customWalkSpeed or normalWalkSpeed
end

-- Example for JumpPower:
local function setJump()
    humanoid.UseJumpPower = true
    humanoid.JumpPower = customJumpPower
end
