-- [[ BOOTSTRAP ]] --
local function safeLoad(func)
    local success, err = pcall(func)
    if not success then warn("Error: " .. tostring(err)) end
end

safeLoad(function()
    local Players = game:GetService("Players")
    local UIS = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local player = Players.LocalPlayer
    
    -- Cleanup
    if player.PlayerGui:FindFirstChild("XenoMenu") then player.PlayerGui.XenoMenu:Destroy() end

    -- [[ UI CREATION ]] --
    local gui = Instance.new("ScreenGui")
    gui.Name = "XenoMenu"
    gui.Parent = player.PlayerGui

    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, 480, 0, 380)
    main.Position = UDim2.new(0.5, -240, 0.5, -190)
    main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    main.BorderSizePixel = 0
    main.Active = true
    main.Parent = gui

    -- Outlines & Corners
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke", main)
    stroke.Color = Color3.fromRGB(60, 60, 60)
    stroke.Thickness = 2

    -- Sidebar (Left)
    local side = Instance.new("Frame")
    side.Size = UDim2.new(0, 140, 1, 0)
    side.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    side.BorderSizePixel = 0
    side.Parent = main
    Instance.new("UICorner", side).CornerRadius = UDim.new(0, 10)

    -- Scrolling Content (Right)
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -160, 1, -20)
    scroll.Position = UDim2.new(0, 150, 0, 10)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 2
    scroll.Parent = main

    local list = Instance.new("UIListLayout", scroll)
    list.Padding = UDim.new(0, 8)

    -- [[ CUSTOM DRAGGING SYSTEM ]] --
    local dragging, dragInput, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = main.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    main.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- [[ FEATURE LIST ]] --
    local flags = {}
    local function addHack(name, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.95, 0, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        btn.Text = "  " .. name
        btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        btn.TextXAlignment = "Left"
        btn.Font = "FredokaOne"
        btn.Parent = scroll
        
        Instance.new("UICorner", btn)
        local bStroke = Instance.new("UIStroke", btn)
        bStroke.Color = Color3.fromRGB(45, 45, 45)

        local active = false
        btn.MouseButton1Click:Connect(function()
            active = not active
            btn.BackgroundColor3 = active and Color3.fromRGB(218, 165, 32) or Color3.fromRGB(30, 30, 30)
            btn.TextColor3 = active and Color3.new(0,0,0) or Color3.new(1,1,1)
            callback(active)
        end)
    end

    -- [[ THE 13 HACKS ]] --
    addHack("Infinite Jump", function(v) flags.infJump = v end)
    addHack("Aimbot (Rivals)", function(v) flags.aim = v end)
    addHack("Auto-Shoot", function(v) flags.auto = v end)
    addHack("Noclip", function(v) flags.noclip = v end)
    addHack("ESP Boxes", function(v) flags.esp = v end)
    addHack("Wallhack (Chams)", function(v) flags.chams = v end)
    addHack("Speed Hack", function(v) player.Character.Humanoid.WalkSpeed = v and 100 or 16 end)
    addHack("Infinite Stamina", function(v) flags.stam = v end)
    addHack("No Recoil", function(v) flags.recoil = v end)
    addHack("Fast Reload", function(v) flags.reload = v end)
    addHack("Fullbright", function(v) game.Lighting.Brightness = v and 2 or 1 end)
    addHack("Anti-AFK", function(v) flags.afk = v end)
    addHack("Auto-Farm Coins", function(v) flags.farm = v end)

    -- Loader Button in Sidebar
    local loadBtn = Instance.new("TextButton", side)
    loadBtn.Size = UDim2.new(0.9, 0, 0, 40)
    loadBtn.Position = UDim2.new(0.05, 0, 0.9, -10)
    loadBtn.Text = "LOAD SABA RUSH"
    loadBtn.BackgroundColor3 = Color3.fromRGB(218, 165, 32)
    Instance.new("UICorner", loadBtn)

    loadBtn.MouseButton1Click:Connect(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/arhamred24-del/sabarushubloaderscript4/refs/heads/main/scccccccccsacwd"))()
    end)

    -- [[ LOGIC LOOPS ]] --
    RunService.RenderStepped:Connect(function()
        if flags.infJump and UIS:IsKeyDown(Enum.KeyCode.Space) then
            player.Character.Humanoid:ChangeState(3)
        end
        if flags.noclip and player.Character then
            for _, p in pairs(player.Character:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end)
end)
