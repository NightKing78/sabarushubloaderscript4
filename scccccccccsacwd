-- [[ UI BUILDERS ]] --
local function addToggle(name, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0.95, 0, 0, 45)
    row.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    row.Parent = content
    Instance.new("UICorner", row)
    Instance.new("UIStroke", row).Color = Color3.fromRGB(50, 50, 50)

    local label = Instance.new("TextLabel")
    label.Text = name
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0.05, 0, 0, 0)
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = "Left"
    label.Font = "FredokaOne"
    label.TextSize = 14
    label.Parent = row

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 22)
    btn.Position = UDim2.new(0.8, 0, 0.25, 0)
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.Text = ""
    btn.Parent = row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", btn)
    circle.Size = UDim2.new(0, 18, 0, 18)
    circle.Position = UDim2.new(0, 2, 0.5, -9)
    circle.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(218, 165, 32) or Color3.fromRGB(60, 60, 60)
        circle:TweenPosition(active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Quad", 0.2)
        callback(active)
    end)
end

